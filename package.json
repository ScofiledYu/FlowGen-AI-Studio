{
  "name": "flowgen-ai-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cross-env PORT=3001 node server/flowgenApiOnly.mjs",
    "dev:full": "concurrently -k \"npm run dev\" \"npm run dev:api\"",
    "prebuild": "node scripts/_fix-chatpanel-final.mjs && node scripts/_fix-regex-lines.mjs && node scripts/apply-chatpanel-zh-ui.mjs && node scripts/fix-chatpanel-ui-remaining.mjs && node scripts/fix-chatpanel-ui-last.mjs && node scripts/fix-visible-chat-ui.mjs && node scripts/fix-chatpanel-chat-strings.mjs && node scripts/fix-chatpanel-fallback-strings.mjs && node scripts/fix-aitop-error-strings.mjs && node scripts/fix-error-display-strings.mjs && node scripts/fix-chatpanel-time-block.mjs && node scripts/test-current-time-answer.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:kling": "tsx test-kling-video.ts",
    "test:llm": "node scripts/llm-model-all-test.mjs",
    "test:llm:switch": "node scripts/llm-model-switch-matrix.mjs",
    "test:llm:context": "node scripts/llm-context-switch-test.mjs",
    "test:llm:combo": "node scripts/llm-combo-test.mjs",
    "test:llm:probe": "tsx scripts/llm-web-search-probe-test.ts",
    "test:panel-refs": "tsx scripts/panel-ref-media-simulation-test.ts",
    "test:ref-upload-env": "tsx scripts/simulate-reference-upload-environment.ts",
    "test:inspector-mentions": "tsx scripts/inspector-at-mention-e2e-test.ts",
    "test:image2-panel-refs": "tsx scripts/image2-panel-refs-test.ts",
    "test:node-details": "tsx scripts/node-details-simulation-test.ts",
    "test:panel-all": "npm run test:panel-refs && npm run test:node-details",
    "test:ref-details": "npm run test:panel-refs && npm run test:node-details && tsx scripts/reference-details-audit-test.ts",
    "test:project-json-details": "tsx scripts/project-json-node-details-test.ts",
    "test:details-all": "npm run test:ref-details && npm run test:project-json-details",
    "test:final": "npm run test:ref-details && npm run test:project-json-details && tsx scripts/all-models-final-test.ts",
    "test:panel-models": "tsx scripts/panel-unified-per-model-matrix-test.ts",
    "test:layout": "tsx scripts/assistant-message-layout-test.ts",
    "test:chat-pipeline": "tsx scripts/chat-pipeline-regression-test.ts",
    "test:chat-live": "tsx scripts/chat-live-smoke-test.ts",
    "test:chat-all": "npm run test:layout && npm run test:chat-pipeline",
    "test:chat-tricky": "tsx scripts/chat-tricky-questions-test.ts",
    "test:chat-tricky:live": "tsx scripts/chat-tricky-questions-test.ts --live",
    "test:e2e:setup-users": "node scripts/e2e-setup-test-users.mjs",
    "test:e2e:isolation": "node scripts/e2e-isolation-verify.mjs",
    "test:workspace-persistence": "node scripts/workspace-persistence-test.mjs",
    "test:workspace-clear-reload": "node scripts/workspace-clear-reload-test.mjs",
    "test:multi-client": "node scripts/multi-client-load-test.mjs",
    "test:mysql": "node scripts/mysql-connection-test.mjs",
    "mysql:init": "node scripts/mysql-init-schema.mjs",
    "mysql:migrate": "node scripts/mysql-ensure-chunks.mjs && node scripts/migrate-json-to-mysql.mjs",
    "mysql:init-v2": "node scripts/mysql-init-schema-v2.mjs",
    "mysql:migrate-relational": "node scripts/migrate-snapshot-to-relational.mjs",
    "repair:project-covers": "node scripts/repair-project-covers-from-disk.mjs"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "express": "^4.22.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.294.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.1",
    "sharp": "^0.33.5",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "formdata-node": "^6.0.3",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^4.0.16"
  }
}

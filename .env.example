# AI / 代理（按需）
# GEMINI_API_KEY=
# AITOP_API_KEY=

# FlowGen 多用户数据目录（上传文件始终在此；业务数据见 FLOWGEN_STORAGE）
# FLOWGEN_DATA_DIR=./data/flowgen

# AITOP100 API（项目列表同步 + 生图生视频计费）
# AITOP_API_BASE_URL=https://aitop100-api.hytch.com
# AITOP_API_KEY=your-aitop-api-key
# 平台管理员/超管同步 AITOP 公司全部项目时，若登录名不是域账号，可指定备用域账号（如 liangyu）
# FLOWGEN_AITOP_ADMIN_DOMAIN_ACCOUNT=liangyu

# 业务数据存储：mysql | json（未设置且 MYSQL_PASSWORD 有值时默认 mysql）
# FLOWGEN_STORAGE=mysql

# JWT（开发与生产都必须设置；未设置时服务端使用可伪造的开发默认值并打安全警告）
# 生成示例（PowerShell）: [Convert]::ToBase64String((1..48|%{Get-Random -Max 256}|%{[byte]$_}))
FLOWGEN_JWT_SECRET=change-me-in-production

# MySQL 5.7（与 Win10 开发机、Windows Server 2012 R2 生产机同版本）
# 连通性: npm run test:mysql  初始化表: npm run mysql:init
# API 探活: GET /flowgen-api/health/db
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=flowgen
MYSQL_PASSWORD=
MYSQL_DATABASE=flowgen
